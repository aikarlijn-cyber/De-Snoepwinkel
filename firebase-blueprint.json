{
  "entities": {
    "enrollment": {
      "title": "Enrollment",
      "description": "A record of a course selection by a user.",
      "type": "object",
      "properties": {
        "courseId": {
          "type": "integer",
          "description": "The unique ID of the course."
        },
        "courseTitle": {
          "type": "string",
          "description": "The title of the course."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the selection was made."
        },
        "userName": {
          "type": "string",
          "description": "The name of the user who made the selection."
        },
        "userEmail": {
          "type": "string",
          "format": "email",
          "description": "The email of the user who made the selection (if logged in)."
        }
      },
      "required": ["courseId", "courseTitle", "timestamp", "userName"]
    }
  },
  "firestore": {
    "/enrollments/{enrollmentId}": {
      "schema": "enrollment",
      "description": "Collection of all course selections."
    }
  }
}
